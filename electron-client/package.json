{
  "name": "mgdemoplus-client",
  "version": "1.0.0",
  "description": "MGDemoPlus 桌面客户端 - 在线德州扑克",
  "author": "MGDemoPlus Team",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "node -e \"var fs=require('fs'),p=require('path');var s='../front/dp_game/dist',d='dist-frontend';try{fs.rmSync(d,{recursive:true,force:true})}catch(e){}fs.cpSync(s,d,{recursive:true});console.log('Copied dist -> dist-frontend')\"",
    "build": "npm run prebuild && electron-builder --win dir",
    "build:cn": "set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ && node scripts/build.js"
  },
  "build": {
    "appId": "com.mgdemoplus.poker",
    "productName": "MGDemoPlus",
    "directories": {
      "output": "MGDemoPlus-win32-x64"
    },
    "files": [
      "main.js",
      "preload.js",
      "config.json",
      "dist-frontend/**/*"
    ],
    "win": {
      "target": "dir",
      "icon": null
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
