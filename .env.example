# =============================================================================
# MGDemoPlus 环境变量示例（复制为 .env 后按需填写；勿提交 .env）
# =============================================================================
# 分层定义与读取顺序：docs/CONFIG_LAYERS.md
# 本机：copy .env.example .env → mvn spring-boot:run / IDE（LocalDotenvLoader 加载）
# Docker：compose 读宿主机 .env 做 ${VAR} 替换，注入 app 容器 environment（镜像内无 .env）
# 不填的 B 类项使用 application.yml 中的 ${ENV:默认} 默认值。
# =============================================================================

# =============================================================================
# A — 密钥（生产公网强烈建议填写 JWT_SECRET、数据库/Redis 口令、ARK 五项）
# =============================================================================

# JWT 签名密钥（UTF-8 ≥32 字节）；未设则用 yml 开发弱默认；轮换后全员需重新登录
JWT_SECRET=

# MySQL（本机默认 localhost:3307；Docker compose 内用 mysql:3306）
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Redis（本机默认 127.0.0.1:6380；Docker compose 内用 redis:6379）
SPRING_DATA_REDIS_HOST=
SPRING_DATA_REDIS_PORT=
SPRING_DATA_REDIS_PASSWORD=

# 方舟大模型 BOT_LLM（五项均非空才走云端推理）
ARK_API_KEY=
ARK_ENDPOINT_ID=
ARK_BASE_URL=

# =============================================================================
# B — 运维可调（可选；不填则用 application.yml 默认）
# =============================================================================

# 大厅幽灵房对齐（多实例部署建议 false）
# MGDEMOPLUS_DP_LOBBY_RECONCILE_ENABLED=true
# MGDEMOPLUS_DP_LOBBY_RECONCILE_MS=60000
# MGDEMOPLUS_DP_QUICK_MATCH_PRUNE_MS=30000
# MGDEMOPLUS_DP_SITE_PRESENCE_TTL_MS=90000

# Redis 缓存 TTL（秒）
# MGDEMOPLUS_CACHE_MUSIC_LIST_TTL_SECONDS=300
# MGDEMOPLUS_CACHE_DP_ROOM_PUBLIC_ROOMS_TTL_SECONDS=120

# 排行榜 MySQL → Redis 同步
# MGDEMOPLUS_LEADERBOARD_SYNC_ENABLED=true
# MGDEMOPLUS_LEADERBOARD_SYNC_INTERVAL_MS=60000
# MGDEMOPLUS_LEADERBOARD_REDIS_TTL_DAYS=14

# 结算持久化
# MGDEMOPLUS_SETTLE_PERSIST_ASYNC_ENABLED=true
# MGDEMOPLUS_SETTLE_PERSIST_QUEUE_CAPACITY=256

# NPC 桌边话
# DP_NPC_TABLE_TALK_ENABLED=true
# DP_NPC_TABLE_TALK_MIN_INTERVAL_MS=2500
# DP_NPC_TABLE_TALK_SPEAK_PROBABILITY=
# DP_NPC_TABLE_TALK_SETTLE_SPEAK_PROBABILITY=

# NPC 规则思考延时
# DP_NPC_RULE_THINK_ENABLED=true
# DP_NPC_RULE_THINK_SNAP_PROBABILITY=0.18
# DP_NPC_RULE_THINK_MAX_MS=4000
# DP_NPC_RULE_THINK_FAST_MIN_MS=500
# DP_NPC_RULE_THINK_FAST_MAX_MS=2000
# DP_NPC_RULE_THINK_FAST_WEIGHT=0.70
# DP_NPC_RULE_THINK_SLOW_MIN_MS=2000
# DP_NPC_RULE_THINK_SLOW_MAX_MS=4000
# DP_NPC_RULE_THINK_SLOW_WEIGHT=0.30

# 方舟 LLM 推理参数（A 五项见上；以下为 B 可调）
# ARK_REASONING_EFFORT=
# ARK_THINKING_TYPE=
# ARK_RESPONSE_JSON_OBJECT=true

# =============================================================================
# C — 本机路径 / 时区（Docker compose 通常已在 environment 注入，可不填）
# =============================================================================

# MGDEMOPLUS_TIME_ZONE=Asia/Shanghai
# MGDEMOPLUS_IMAGES_FILE_LOCATION=file:P:/javaworkspace/DPGameFiles/
# MGDEMOPLUS_MUSIC_FILE_LOCATION=file:P:/javaworkspace/DPGameFiles/music/
# LOG_FILE=logs/mgdemoplus.log
