# MGDemoPlus / DP 游戏 — 环境变量说明（可提交 Git）
#
# 使用：复制为 .env 后按需填写私密项。
#   copy .env.example .env   （PowerShell: Copy-Item .env.example .env）
#
# 与代码的关系：
#   · src/main/resources/application.properties 已用 ${环境变量:默认值}，本机不配 .env 也能跑。
#   · 根目录 .env 由 LocalDotenvLoader 在 main 里、Spring 启动前加载（工作目录须为仓库根）；Docker 由 compose 注入环境变量。
#   · 私密项只应出现在 .env，勿提交 .env。
#
# —— 下面两段不要混用场景 ——
#   A) docker compose / docker-compose.hub.yml：只使用「与 compose 里 ${变量} 对应」的项（见各文件注释）。
#   B) 本机 IDEA / mvn 直接跑 Spring：可再写 SPRING_*、MGDEMOPLUS_* 覆盖 application.properties。
#      这些不会注入 Hub 编排里的 app 容器（容器内连 mysql/redis 由 compose 写死）。

# ---------- A：Docker Compose / Hub 镜像部署 ----------
DOCKER_REGISTRY=1933886418
IMAGE_TAG=v1.0.1
MYSQL_ROOT_PASSWORD=mgdemo_root
REDIS_PASSWORD=mgdemo_redis
NGINX_HTTP_PORT=80
# 宿主机映射应用 8088 的端口（本机 8088 被占用时改为 9080 等）
APP_HOST_PORT=8088

# ---------- 密钥与方舟（Hub 与本地 java 均会读取 compose / .env 注入）----------
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long
ARK_API_KEY=
ARK_ENDPOINT_ID=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
# ARK_REASONING_EFFORT=low
# ARK_THINKING_TYPE=enabled

# 曲库列表 Redis 缓存 TTL（秒）；Hub 编排已传入 app 容器
MGDEMOPLUS_CACHE_MUSIC_LIST_TTL_SECONDS=300

# ---------- B：仅本机直接运行 Spring Boot（非 Docker）----------
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/school_db?useSSL=false
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=
# SPRING_DATA_REDIS_HOST=127.0.0.1
# SPRING_DATA_REDIS_PORT=6379
# SPRING_DATA_REDIS_PASSWORD=
# MGDEMOPLUS_IMAGES_FILE_LOCATION=file:P:/javaworkspace/DPGameFiles/
# MGDEMOPLUS_MUSIC_FILE_LOCATION=file:P:/javaworkspace/DPGameFiles/music/
