# MGDemoPlus / DP 游戏 — 环境变量说明（可提交 Git）
#
# 使用：复制为 .env 后按需填写私密项。
#   copy .env.example .env   （PowerShell: Copy-Item .env.example .env）
#
# 与代码的关系：
#   · src/main/resources/application.properties 已用 ${环境变量:默认值}，本机不配 .env 也能跑。
#   · 根目录 .env 由 LocalDotenvLoader 在启动前加载（工作目录须为仓库根）；Docker 由 compose 注入。
#   · 私密项只应出现在 .env，勿提交 .env。

# ---------- Docker Compose（仅执行 docker compose / hub 编排时需要）----------
DOCKER_REGISTRY=
IMAGE_TAG=v1.0.1
# MYSQL_ROOT_PASSWORD=mgdemo_root
# REDIS_PASSWORD=mgdemo_redis
# NGINX_HTTP_PORT=80

# ---------- 密钥与方舟（可选；不填则走 application.properties 默认或留空）----------
JWT_SECRET=
ARK_API_KEY=
ARK_ENDPOINT_ID=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
# ARK_REASONING_EFFORT=low
# ARK_THINKING_TYPE=enabled

# ---------- 仅当本机与 application.properties 默认值不一致时再取消注释 ----------
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/school_db?useSSL=false
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=
# SPRING_DATA_REDIS_HOST=
# SPRING_DATA_REDIS_PORT=
# SPRING_DATA_REDIS_PASSWORD=
# MGDEMOPLUS_IMAGES_FILE_LOCATION=file:P:/javaworkspace/DPGameFiles/
# MGDEMOPLUS_MUSIC_FILE_LOCATION=file:P:/javaworkspace/DPGameFiles/music/
# MGDEMOPLUS_CACHE_MUSIC_LIST_TTL_SECONDS=300
